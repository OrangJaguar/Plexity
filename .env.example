# Local dev only — copy to .env (gitignored). Base44 preview injects these automatically.
# App ID must match base44/.app.jsonc and your *.base44.app URL.
VITE_BASE44_APP_ID=69f7f418be004e32dd4e8acc
VITE_BASE44_FUNCTIONS_VERSION=
VITE_BASE44_APP_BASE_URL=https://veridian-tools.base44.app

# Dev script only — scripts/import-college-scorecard.mjs (not used by the app at runtime)
# Request a free key at https://api.data.gov/signup/
# COLLEGE_SCORECARD_API_KEY=

# Base44 function env (toolsMarketData) — optional override for outbound User-Agent
# MARKET_DATA_USER_AGENT=Mozilla/5.0 (compatible; VeridianTools/1; +https://example.com)
# APP_NAME=VeridianTools
# APP_VERSION=1
# APP_CONTACT_URL=https://veridian-tools.base44.app
