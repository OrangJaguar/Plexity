# Role: api | fetch-worker | media-worker | cleanup-worker | discovery-worker | package-worker | ai-worker | egress-proxy
ROLE=api

# Kill switches (string "false" disables)
ACCEPT_NEW_JOBS=true
ENABLE_YOUTUBE_CONNECTOR=false
# RSS/Atom feed discovery (Plan 6). Independent of YouTube.
ENABLE_FEED_CONNECTOR=true

# Plan 7 AI worker kill switches
ENABLE_AI_PROVIDER=false
ACCEPT_NEW_AI_JOBS=true
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PRIMARY_MODEL=gpt-4o-mini
AI_FALLBACK_MODEL=gpt-4o-mini

# Encrypt discovery source URLs at rest (hex 64-char AES key or falls back to HMAC envelope)
ENCRYPTION_KEY=

# HMAC auth (must match Base44 CONVERTER_MEDIA_HMAC_SECRET)
HMAC_SECRET=change-me-in-production-use-openssl-rand-hex-32

# HTTP
PORT=8080
HOST=0.0.0.0

# PostgreSQL
DATABASE_URL=postgres://converter:converter@postgres:5432/converter_media

# S3-compatible storage (MinIO in compose)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=converter-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Signed download URLs served to admins (public-facing MinIO gateway or CDN)
S3_PUBLIC_ENDPOINT=http://localhost:9000

# Worker identity (unique per replica)
WORKER_ID=worker-local-1

# Fetch worker egress (must route through egress-proxy in production)
EGRESS_PROXY_URL=http://egress-proxy:3128
HTTP_PROXY=http://egress-proxy:3128
HTTPS_PROXY=http://egress-proxy:3128

# Optional callback to Base44 adminConverterApi (worker progress)
CALLBACK_URL=
CALLBACK_HMAC_SECRET=

# Polling intervals (ms)
WORKER_POLL_MS=2000
CLEANUP_INTERVAL_MS=60000
LEASE_TTL_MS=120000
LEASE_HEARTBEAT_MS=30000

# Job retention
READY_JOB_TTL_MS=3600000
ORPHAN_ARTIFACT_TTL_MS=86400000
